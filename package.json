{
  "name": "10x",
  "version": "1.3.17",
  "license": "MIT",
  "author": "BrightSideDeveloper",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist-electron/main/index.js",
  "description": "10x Agentic Workspace",
  "scripts": {
    "dev": "vite",
    "build:bundle": "tsc --noEmit && vite build",
    "build": "pnpm run build:bundle && electron-builder",
    "build:mac": "pnpm run build:bundle && electron-builder --mac",
    "build:linux": "pnpm run build:bundle && electron-builder --linux",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "bump": "node scripts/bump.js",
    "postinstall": "electron-rebuild -f -w node-pty",
    "rebuild:native": "electron-rebuild -f -w node-pty"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@electron/rebuild",
      "electron",
      "esbuild",
      "msw",
      "node-pty"
    ],
    "patchedDependencies": {
      "@electron/notarize@2.5.0": "patches/@electron__notarize@2.5.0.patch"
    }
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "^5.69.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "fix-path": "^5.0.0",
    "lucide-react": "^0.487.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@electron/rebuild": "^4.0.3",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.5",
    "picocolors": "^1.1.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.tenx.desktop",
    "productName": "10x",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ],
    "mac": {
      "artifactName": "${productName}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": {
        "teamId": "VR3V6J7X67"
      }
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "brightsidedeveloper",
      "repo": "10x"
    }
  }
}
